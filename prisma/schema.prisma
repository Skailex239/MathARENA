// MathArena — Prisma schema (SQLite)
// Compétitif : 3 modes (Classique/Rapide/Blitz) avec Elo séparé par mode.
// Entraînement : sans Elo (exercises Vs IA / Sprint / Catégorie / Défi / Marathon).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Le joueur humain local (id=1) + les bots du leaderboard.
model Player {
  id          Int      @id @default(autoincrement())
  isBot       Boolean  @default(false)
  name        String

  // Compétitif — Elo séparé par mode (style Chess.com)
  eloClassique Int     @default(1000)
  eloRapide    Int     @default(1000)
  eloBlitz     Int     @default(1000)
  winsClassique Int    @default(0)
  lossesClassique Int  @default(0)
  winsRapide   Int     @default(0)
  lossesRapide Int     @default(0)
  winsBlitz    Int     @default(0)
  lossesBlitz  Int     @default(0)

  // Entraînement (sans Elo, juste compteur)
  winsArena   Int      @default(0)
  lossesArena Int      @default(0)

  // Global
  level       Int      @default(1)
  xp          Int      @default(0)
  title       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  matches     Match[]

  @@map("players")
}

/// Historique des duels du joueur local.
model Match {
  id            Int      @id @default(autoincrement())
  playerId      Int
  player        Player   @relation(fields: [playerId], references: [id])
  universe      String   @default("competitive") // "competitive" | "arena"
  opponentName  String
  result        String   // WIN | LOSE
  playerScore   Int      @default(0)  // score du joueur (points ou questions réussies)
  opponentScore Int      @default(0)  // score adverse
  avgTimeMs     Int      @default(0)
  accuracy      Float    @default(0)
  mode          String   // CLASSIQUE | RAPIDE | BLITZ | PRACTICE
  eloChange     Int      @default(0)
  eloAfter      Int      @default(1000)
  xpGained      Int      @default(0)
  createdAt     DateTime @default(now())

  @@map("matches")
}
