// MathArena — Prisma schema (SQLite)
// Deux univers : Compétitif (pur skill, Elo officiel) & Arène (gaming, classes/sorts/PV/combos)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Le joueur humain local (id=1) + les bots du leaderboard.
model Player {
  id          Int      @id @default(autoincrement())
  isBot       Boolean  @default(false)
  name        String

  // Compétitif (pur skill — Chess.com style)
  elo         Int      @default(1000) // elo compétitif (principal)
  wins        Int      @default(0)    // victoires compétitif
  losses      Int      @default(0)    // défaites compétitif

  // Arène (gaming — classes/sorts/PV/combos)
  eloArena    Int      @default(1000)
  winsArena   Int      @default(0)
  lossesArena Int      @default(0)
  bestCombo   Int      @default(0) // arène uniquement

  // Global
  level       Int      @default(1)
  xp          Int      @default(0)
  title       String?
  class       String? // classe préférée (arène)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  matches     Match[]

  @@map("players")
}

/// Historique des duels du joueur local (compétitif & arène).
model Match {
  id            Int      @id @default(autoincrement())
  playerId      Int
  player        Player   @relation(fields: [playerId], references: [id])
  universe      String   @default("competitive") // "competitive" | "arena"
  playerClass   String?  // arène uniquement
  opponentClass String?  // arène uniquement
  opponentName  String
  result        String   // WIN | LOSE
  playerHP      Int      @default(0)  // arène: PV restants ; compétitif: score du joueur
  opponentHP    Int      @default(0)  // arène: PV restants ; compétitif: score adverse
  maxCombo      Int      @default(0)  // arène uniquement
  avgTimeMs     Int      @default(0)
  accuracy      Float    @default(0)
  mode          String   // PRACTICE | QUICK | BLITZ | RANKED
  eloChange     Int      @default(0)
  eloAfter      Int      @default(1000)
  xpGained      Int      @default(0)
  createdAt     DateTime @default(now())

  @@map("matches")
}
